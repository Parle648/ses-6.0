# Dockerfile.dev
FROM node:20-alpine

WORKDIR /app

# Install ts-node-dev globally for development
RUN npm install -g ts-node-dev --force

# Copy package files
COPY package*.json ./

# Install all dependencies
RUN npm ci --force

# Copy source code
COPY . .

# Expose port
EXPOSE 7000

# Start with hot-reload
CMD ["npm", "run", "server:watch"]