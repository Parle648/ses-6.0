  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node .",
    "prestart": "npm run build",
    "server:watch": "ts-node-dev --respawn --transpile-only --poll --watch src --ignore-watch node_modules src/index.ts",
    "prebuild": "npm run lint",
    "lint:fix": "eslint --cache --ext .ts . --fix",
    "lint": "eslint --cache src/",
    "test:unit": "jest --config=jest.config.js",
    "docker-build:dev": "docker build -t my-node-image-dev:0.0.2 -f dockerfile.dev .",
    "docker-run:dev": "docker run -it --network host -v %cd%:/app -v /app/node_modules my-node-image-dev:0.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.24",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node-pg-migrate": "^2.3.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "body-parser": "^2.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-http-context": "^2.0.1",
    "log4js": "^6.9.1",
    "multer": "^2.1.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.3",
    "swagger-ui-express": "^5.0.1"
  }
}
